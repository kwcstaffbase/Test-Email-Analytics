{
  "testEnvironment": "jsdom",
  "moduleNameMapper": {
    "\\.module\\.css$": "identity-obj-proxy"
  },
  "transform": {
    "^.+\\.(ts|tsx|js|jsx)$": "babel-jest"
  },
  "testMatch": [
    "**/__tests__/**/*.(ts|tsx)",
    "**/?(*.)+(spec|test).(ts|tsx)"
  ],
  "collectCoverageFrom": [
    "src/**/*.{ts,tsx}",
    "!src/**/*.d.ts"
  ]
}
